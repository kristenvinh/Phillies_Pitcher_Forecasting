            <column caption='Timeframe' datatype='string' name='[Calculation_1556166936465408]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [match_date] = {FIXED [player_name] : MAX([match_date])} &#10;THEN &quot;Most Recent Game&quot; &#10;ELSE &quot;Historical Baseline&quot; &#10;END' />
            </column>
            <column caption='Baseline Mean Velocity' datatype='real' name='[Calculation_2317992076058624]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [player_name], [pitch_type] : &#10;    AVG( IIF([Calculation_1556166936465408] = &quot;Historical Baseline&quot;, [velocity], NULL) ) &#10;}' />
            </column>
            <column caption='Baseline StDev Velocity' datatype='real' name='[Calculation_2317992076099585]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [player_name], [pitch_type] : &#10;    STDEV( IIF([Calculation_1556166936465408] = &quot;Historical Baseline&quot;, [velocity], NULL) ) &#10;}' />
            </column>
            <column caption='Recent Game Mean Velocity' datatype='real' name='[Calculation_2317992076234754]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [player_name], [pitch_type] : &#10;    AVG( IIF([Calculation_1556166936465408] = &quot;Most Recent Game&quot;, [velocity], NULL) ) &#10;}' />
            </column>
            <column caption='Velocity Drift Alert' datatype='string' name='[Calculation_2317992076357635]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ABS([Calculation_2317992076234754] - [Calculation_2317992076058624]) &gt; (2 * [Calculation_2317992076099585]) &#10;THEN &quot;⚠️ DRIFT DETECTED&quot; &#10;ELSE &quot;✅ Stable&quot; &#10;END' />
            </column>
